{
    "name": "indowater/api",
    "description": "IndoWater Prepaid Water Meter Management System API",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "IndoWater System",
            "email": "info@indowater.example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "doctrine/dbal": "^3.5",
        "doctrine/orm": "^2.13",
        "doku/doku-php-library": "^1.0",
        "firebase/php-jwt": "^6.3",
        "guzzlehttp/guzzle": "^7.5",
        "midtrans/midtrans-php": "^2.6",
        "monolog/monolog": "^2.8",
        "php-di/php-di": "^6.4",
        "phpmailer/phpmailer": "^6.6",
        "ramsey/uuid": "^4.5",
        "slim/psr7": "^1.5",
        "slim/slim": "^4.10",
        "slim/twig-view": "^3.3",
        "symfony/mailer": "^6.1",
        "symfony/mime": "^6.1",
        "vlucas/phpdotenv": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "mockery/mockery": "^1.5",
        "fakerphp/faker": "^1.20",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.8",
        "phpmd/phpmd": "^2.13",
        "friendsofphp/php-cs-fixer": "^3.11",
        "vimeo/psalm": "^4.27",
        "infection/infection": "^0.26.16",
        "phpbench/phpbench": "^1.2",
        "phpmetrics/phpmetrics": "^2.8",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "IndoWater\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IndoWater\\Api\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "test": "phpunit",
        "lint": "phpcs",
        "fix": "phpcbf",
        "analyze": "phpstan analyze",
        "md": "phpmd src text phpmd.xml",
        "psalm": "psalm",
        "infection": "infection",
        "bench": "phpbench run --report=aggregate",
        "metrics": "phpmetrics --report-html=metrics ."
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "infection/extension-installer": true
        }
    }
}
